# ── SentinalScan Frontend Environment Variables ──────────────

# Backend API URL (must include /api/v1 path prefix)
VITE_API_URL=http://localhost:8000/api/v1

# API key — must match the backend's API_KEY value
VITE_API_KEY=your_api_key_here

# WebSocket URL (protocol ws:// or wss://)
VITE_WS_URL=ws://localhost:8000
