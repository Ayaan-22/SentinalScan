# ── SentinalScan Backend Environment Variables ────────────────
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────
# API key for authenticating frontend requests.
# MUST be at least 32 characters for security.
# Startup will fail if this is too short or set to a default value.
# Generate a strong random key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=generate_a_64_character_hex_key_here

# Secret key for session signing / JWT / Internal crypto.
# Keep this extremely private and do not share between environments.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_64_character_hex_secret_here

# ── Logging ───────────────────────────────
# Options: DEBUG (Verbose), INFO (Standard), WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Output format for logs.
# Options: json (Best for cloud/Docker), text (Best for local dev)
LOG_FORMAT=json

# ── CORS Configuration ────────────────────
# Origins allowed to call the API. 
# MUST be a JSON list of strings.
# For local dev: ["http://localhost:5173", "http://localhost:3000"]
# For production: ["https://scan.yourdomain.com"]
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# ── Crawler / Engine Tunables ─────────────
# Maximum concurrent HTTP requests during crawling
MAX_CONCURRENT_REQUESTS=20
# Default timeout for crawler requests (seconds)
CRAWLER_TIMEOUT=15
# User agent string to use for all requests
USER_AGENT=SentinalScan/2.1.0 (Security Auditor; +https://github.com/Ayaan-22/SentinalScan)
